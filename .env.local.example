# Aether-Tactical 로컬 환경 변수 샘플
# 실제 키를 넣어 `.env.local`로 저장 (커밋 금지, .gitignore 처리됨)

# === Grok Imagine API (옵션) ===
# scripts/generate-fleet-images.mjs 실행 시 필요.
# 발급: https://x.ai/api
# 비용: grok-imagine-image-pro $0.07/장, grok-imagine-image $0.02/장
GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === OpenAI (부사령관 서브에이전트용) ===
# openai-coder 서브에이전트 (program-main/tools/openai_coder/coder.py)가 자동 로드.
# Claude Code가 해결 못 하거나 교차 검증 필요할 때 o3-mini/o1로 위임.
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Google GenAI (Lyria BGM 생성용) ===
# scripts/generate-bgm.mjs에서 사용. lyria-3-clip-preview (30s) / lyria-3-pro-preview (multi-min).
# 발급: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
